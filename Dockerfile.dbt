FROM python:3.12-slim

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# Install only dbt dependencies from the dedicated subproject.
COPY dbt/pyproject.toml dbt/uv.lock ./dbt/
RUN uv sync --frozen --project /app/dbt

# Copy dbt project files.
COPY dbt ./dbt

# Install dbt packages declared in packages.yml so runtime containers can run dbt directly.
RUN /app/dbt/.venv/bin/dbt deps --project-dir /app/dbt --profiles-dir /app/dbt

ENV UV_PROJECT_ENVIRONMENT=/app/dbt/.venv
ENV PATH="/app/dbt/.venv/bin:$PATH"

WORKDIR /app/dbt
ENTRYPOINT ["dbt"]
